<?xml version="1.0" encoding="utf-8"?>
    <ScrollView
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:id="@+id/main"
    android:scrollbars="none"

        tools:context=".AddTransactionActivity"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        android:fillViewport="true"
 >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="40dp">
            <RelativeLayout
                android:id="@+id/relativeLayout4"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@android:color/white"


                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <LinearLayout
                    android:id="@+id/btnBack"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/back"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@string/back"
                        android:src="@drawable/arrowback" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:fontFamily="@font/poppinsregular"
                        android:text="Back"
                        android:textColor="#1F2937"
                        android:textSize="14sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:fontFamily="@font/poppinsregular"
                    android:letterSpacing="0.05"
                    android:text="@string/transaction_details"
                    android:textColor="#1F2937"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/add_new_entry"
                android:textColor="#11183E"
                android:textSize="30sp"
                android:textStyle="bold"
                android:gravity="center"


                android:fontFamily="@font/poppinssemibold" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/enter_amount"
                android:textColor="#11183E"
                android:fontFamily="@font/poppinslight"
                android:textSize="14sp"
                android:gravity="center"
                />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹"
                    android:textColor="#075292"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="8dp" />

                <EditText
                    android:id="@+id/et_amount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:autofillHints="no"
                    android:hint="@string/_0_00"
                    android:layout_gravity="start"
                    android:inputType="numberDecimal"
                    android:textColorHint="#C5CAE9"
                    android:textColor="#11183E"
                    android:textSize="48sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/robot1"
                    android:background="@null"
                    android:minWidth="120dp"
                    android:gravity="start" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/select_category"
                android:fontFamily="@font/poppinsmedium"
                android:textColor="#11183E"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="14dp"
                android:layout_marginTop="8dp" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false" android:orientation="horizontal"
                android:layout_marginBottom="12dp">


                <LinearLayout
                    android:id="@+id/cat_shopping"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_category_selector"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <ImageView
                        android:id="@+id/icon_shopping"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:importantForAccessibility="no" android:src="@drawable/ic_shopping"
                        app:tint="#11183E" />

                    <TextView
                        android:id="@+id/label_shopping"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/shopping"
                        android:textColor="#11183E"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:clickable="true"
                    android:focusable="true"
                    android:id="@+id/cat_dining"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp"
                    android:background="@drawable/bg_category_selector"
                    android:layout_marginEnd="8dp">

                    <ImageView
                        android:id="@+id/icon_dining"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:importantForAccessibility="no" android:src="@drawable/ic_dining"
                        app:tint="#11183E" />

                    <TextView
                        android:id="@+id/label_dining"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dining"
                        android:textColor="#11183E"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp" />
                </LinearLayout>


                <LinearLayout
                    android:clickable="true"
                    android:focusable="true"
                    android:id="@+id/cat_transport"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp"
                    android:background="@drawable/bg_category_selector"
                    android:layout_marginEnd="8dp">

                    <ImageView
                        android:id="@+id/icon_transport"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:importantForAccessibility="no"
                        android:src="@drawable/ic_transport"
                        app:tint="#11183E" />

                    <TextView
                        android:id="@+id/label_transport"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/travel"
                        android:textColor="#11183E"
                        android:textSize="11sp"
                        android:layout_marginTop="6dp" />
                </LinearLayout>


                <LinearLayout
                    android:clickable="true"
                    android:focusable="true"
                    android:id="@+id/cat_movies"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp"
                    android:background="@drawable/bg_category_selector">

                    <ImageView
                        android:id="@+id/icon_movie"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:importantForAccessibility="no" android:src="@drawable/ic_movie"
                        app:tint="#11183E" />

                    <TextView
                        android:id="@+id/label_movie"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/movies"
                        android:textColor="#11183E"
                        android:textSize="11sp"
                        android:layout_marginTop="6dp" />
                </LinearLayout>

            </LinearLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false" android:orientation="horizontal"
                android:layout_marginBottom="16dp">


                <LinearLayout
                    android:clickable="true"
                    android:focusable="true"
                    android:id="@+id/cat_rent"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp"
                    android:background="@drawable/bg_category_selector"
                    android:layout_marginEnd="8dp">

                    <ImageView
                        android:id="@+id/icon_rent"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:importantForAccessibility="no"
                        android:src="@drawable/ic_rent"
                        app:tint="#11183E" />

                    <TextView
                        android:id="@+id/label_rent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/rent"
                        android:textColor="#11183E"
                        android:textSize="11sp"
                        android:layout_marginTop="6dp" />
                </LinearLayout>


                <LinearLayout
                    android:clickable="true"
                    android:focusable="true"
                    android:id="@+id/cat_health"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp"
                    android:background="@drawable/bg_category_selector"
                    android:layout_marginEnd="8dp">

                    <ImageView
                        android:id="@+id/icon_medical"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:importantForAccessibility="no" android:src="@drawable/ic_medical"
                        app:tint="#11183E" />

                    <TextView
                        android:id="@+id/label_medical"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/health"
                        android:textColor="#11183E"
                        android:textSize="11sp"
                        android:layout_marginTop="6dp" />
                </LinearLayout>


                <LinearLayout
                    android:clickable="true"
                    android:focusable="true"
                    android:id="@+id/cat_gym"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp"
                    android:background="@drawable/bg_category_selector"
                    android:layout_marginEnd="8dp">

                    <ImageView
                        android:id="@+id/icon_gym"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:importantForAccessibility="no" android:src="@drawable/ic_gym"
                        app:tint="#11183E" />

                    <TextView
                        android:id="@+id/label_gym"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/gym"
                        android:textColor="#11183E"
                        android:textSize="11sp"
                        android:layout_marginTop="6dp" />
                </LinearLayout>


                <LinearLayout
                    android:clickable="true"
                    android:focusable="true"
                    android:id="@+id/cat_other"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp"
                    android:background="@drawable/bg_category_selector">

                    <ImageView
                        android:id="@+id/icon_others"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:importantForAccessibility="no" android:src="@drawable/ic_others"
                        app:tint="#11183E" />

                    <TextView
                        android:id="@+id/label_others"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/other"
                        android:textColor="#11183E"
                        android:textSize="11sp"
                        android:layout_marginTop="6dp" />
                </LinearLayout>

            </LinearLayout>



            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"

                android:layout_margin="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:background="@drawable/bg_wallet_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="18dp"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/title"
                        android:textColor="#075292"
                        android:textSize="11sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.15"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:importantForAccessibility="no" android:src="@drawable/ic_title"
                            app:tint="#606470"
                            android:layout_marginEnd="12dp" />

                        <EditText
                            android:id="@+id/et_title"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:hint="@string/e_g_grocery_shopping"
                            android:importantForAutofill="no" android:textColorHint="#C5CAE9"
                            android:textColor="#11183E"
                            android:textSize="15sp"
                            android:paddingStart="8dp"

                            android:background="@drawable/add_new_selector"
                            android:inputType="textCapSentences"
                            android:maxLines="1" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:background="@drawable/bg_wallet_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="18dp"
                   android:padding="12dp"
                    >

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/date"
                        android:textColor="#075292"
                        android:textSize="11sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.15"
                        android:textStyle="bold"
                        android:layout_marginBottom="10dp" />

                    <LinearLayout
                        android:id="@+id/ll_date_picker"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:importantForAccessibility="no"
                            android:src="@drawable/ic_calender"
                            app:tint="#606470"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:fontFamily="@font/poppinsmedium"
                            android:id="@+id/tv_date"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/today_oct_24_2023"
                            android:textColor="#11183E"
                            android:textSize="15sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"

                android:padding="12dp"
                android:background="@drawable/bg_wallet_container">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/select_mode"
                    android:textColor="#075292"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.15"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />


                <LinearLayout
                    android:clickable="true"
                    android:focusable="true"
                    android:id="@+id/wallet_item"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="12dp"
                    android:background="@drawable/bg_wallet_item"
                    android:layout_marginBottom="10dp">


                    <ImageView
                        android:id="@+id/imgWallet"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_wallet_icon"
                        android:importantForAccessibility="no"
                        android:padding="8dp"
                        android:src="@drawable/ic_bank"
                        app:tint="#075292"/>


                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:fontFamily="@font/poppinsmedium"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:id="@+id/tvWalletName"
                            android:text="@string/income"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#11183E"/>

                        <TextView
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:id="@+id/tvWalletAmount"
                            android:text="@string/amount_credit"
                            android:textSize="11sp"
                            android:textColor="#9E9E9E"/>
                    </LinearLayout>


                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/rb_income"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:textSize="14sp"
                        android:textColor="#11183E"
                        android:fontFamily="@font/poppinsregular"
                        app:buttonTint="@color/primary1"
                        android:checked="true"/>

                </LinearLayout>
                <LinearLayout
                    android:clickable="true"
                    android:focusable="true"
                    android:id="@+id/expanse_item"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="12dp"
                    android:background="@drawable/bg_wallet_item"
                    android:layout_marginBottom="10dp">


                    <ImageView
                        android:id="@+id/imgexpanse"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_wallet_icon"
                        android:importantForAccessibility="no"
                        android:padding="8dp"
                        android:src="@drawable/ic_expense"
                        app:tint="#075292"/>


                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:id="@+id/tvexpanseName"
                            android:text="@string/expense"
                            android:fontFamily="@font/poppinsmedium"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#11183E"/>

                        <TextView
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"

                            android:text="@string/amount_debit"
                            android:textSize="11sp"
                            android:textColor="#9E9E9E"/>
                    </LinearLayout>


                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/rb_expense"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:textSize="14sp"
                        android:textColor="#11183E"
                        android:fontFamily="@font/poppinsregular"
                        app:buttonTint="@color/primary1"
                        />

                </LinearLayout>
            </LinearLayout>
            <androidx.appcompat.widget.AppCompatButton
                android:layout_marginTop="16dp"
                android:id="@+id/btn_add_transaction"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:fontFamily="@font/poppinsmedium"
                android:text="@string/add_transaction"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/bg_btn_gradient"
                android:layout_marginBottom="12dp" />


            <TextView
                android:fontFamily="@font/poppinslight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/all_transactions_are_encrypted_and_secured_nusing_256_bit_protocol"
                android:textColor="#9E9E9E"
                android:textSize="11sp"
                android:gravity="center"
                android:lineSpacingExtra="3dp" />





        </LinearLayout>

    </ScrollView>
